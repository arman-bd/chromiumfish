+uint32_t BaseRenderingContext2D::EnsureBridgeCanvas() {
+  // Returns the canvas id, allocating one on first call. 0 means the
+  // bridge is disabled — callers skip forwarding in that case.
+  auto* b = blink::canvas_bridge::CanvasBridgeClient::Get();
+  if (!b->IsEnabled()) {
+    return 0;
+  }
+  auto* host = GetCanvasRenderingContextHost();
+  if (!host || host->IsOffscreenCanvas()) {
+    return 0;
+  }
+  auto* el = static_cast<HTMLCanvasElement*>(host);
+  if (el->bridge_canvas_id_) {
+    return el->bridge_canvas_id_;
+  }
+  uint32_t id = b->AllocateCanvasId();
+  if (!id) {
+    return 0;
+  }
+  el->bridge_canvas_id_ = id;
+  b->Send(blink::canvas_bridge::MsgBuilder::CreateCanvas2D(
+      id, el->width(), el->height(),
+      /*opaque=*/!CreationAttributes().alpha));
+  return id;
+}
